# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data files (não versionar dados)
data/input/*
data/output/*
data/processed/*
!data/input/.gitkeep
!data/output/.gitkeep
!data/processed/.gitkeep

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Temp
*.tmp
*.bak
